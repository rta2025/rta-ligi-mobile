{
  "expo": {
    "name": "RTA Ligi",
    "slug": "rta-ligi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "rtaligi",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B3B2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rizetenisakademisi.rtaligi"
    },
    "android": {
      "package": "com.rizetenisakademisi.rtaligi",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B3B2E"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": []
  }
}
